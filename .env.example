# App Configuration
APP_NAME="Document Intelligence Service"
APP_VERSION="1.0.0"
API_PREFIX="/api/v1"
ENV="development"

# Model Registry Configuration
MODEL_DIR="./models"
ACTIVE_BACKEND="onnx"

# Active Model Versions
CLASSIFIER_VERSION="v1"
DETECTOR_VERSION="v1"
OCR_VERSION="v1"

# Observability
LOG_LEVEL="INFO"

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
